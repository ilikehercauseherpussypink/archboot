#!/usr/bin/env bash

is_interactive() {
    [[ -t 0 && -t 1 ]]
}

yesno() {
    local question=$1 default=${2:-n} answer prompt_hint

    if (( ${ASSUME_YES:-0} )); then
        [[ $default == s || $default == y ]]
        return
    fi
    if ! is_interactive; then
        [[ $default == s || $default == y ]]
        return
    fi

    if [[ $default == s || $default == y ]]; then
        prompt_hint='S/n'
    else
        prompt_hint='s/N'
    fi

    while true; do
        read -r -p "> [?] $question [$prompt_hint] " answer || answer=''
        answer=${answer,,}
        [[ -z $answer ]] && answer=$default
        case $answer in
            s|sim|y|yes) return 0 ;;
            n|nao|não|no) return 1 ;;
            *) warn 'responda com s ou n' ;;
        esac
    done
}

ask_reconfigure() {
    local description=$1 question=${2:-"$1. deseja refazer?"}

    if (( ${DRY_RUN:-0} )); then
        printf '> [dry-run] perguntaria se deve refazer %s\n' "$description"
        return 1
    fi
    if (( ${ASSUME_YES:-0} || ${CI_MODE:-0} == 1 || ${PLAN_ONLY:-0} || ${DOCTOR_ONLY:-0} )); then
        return 1
    fi
    yesno "$question" n
}

ask_additive() {
    local question=$1

    if (( ${DRY_RUN:-0} )); then
        printf '> [dry-run] perguntaria se deve %s\n' "$question"
        return 0
    fi
    if (( ${ASSUME_YES:-0} )); then
        return 0
    fi
    if (( ${CI_MODE:-0} == 1 || ${PLAN_ONLY:-0} || ${DOCTOR_ONLY:-0} )); then
        return 1
    fi
    yesno "$question" s
}

prompt() {
    local variable=$1 question=$2 default=${3:-} answer

    if (( ${ASSUME_YES:-0} )); then
        printf -v "$variable" '%s' "$default"
        return 0
    fi
    if ! is_interactive; then
        printf -v "$variable" '%s' "$default"
        return 0
    fi

    if [[ -n $default ]]; then
        read -r -p "> [?] $question [$default]: " answer || answer=''
        answer=${answer:-$default}
    else
        read -r -p "> [?] $question: " answer || answer=''
    fi
    printf -v "$variable" '%s' "$answer"
}

pause() {
    local message=${1:-'Pressione Enter para continuar.'}
    (( ${ASSUME_YES:-0} )) && return 0
    is_interactive || return 0
    read -r -p "> [?] $message" _ || true
}
