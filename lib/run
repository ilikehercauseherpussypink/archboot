#!/usr/bin/env bash

_render_command() {
    local arg rendered=''
    for arg in "$@"; do
        printf -v rendered '%s %q' "$rendered" "$arg"
    done
    printf '%s' "$rendered"
}

_log_command() {
    local rendered=''
    rendered=$(_render_command "$@")
    printf 'COMMAND:%s\n' "$rendered" | redact_sensitive >>"$LOG_FILE"
}

_print_command() {
    local rendered=''
    rendered=$(_render_command "$@")
    printf '> [cmd]%s\n' "$rendered" | redact_sensitive
}

dry_run_msg() {
    local rendered=''
    rendered=$(_render_command "$@")
    printf '> [dry-run]%s\n' "$rendered" | redact_sensitive
}

run_cmd() {
    local label=$1
    shift
    local -a command=("$@")
    local status

    if (( DRY_RUN )); then
        dry_run_msg "${command[@]}"
        return 0
    fi

    _log_command "${command[@]}"
    if (( VERBOSE )); then
        _print_command "${command[@]}"
        set +e
        "${command[@]}" 2>&1 | redact_sensitive | tee -a "$LOG_FILE"
        status=${PIPESTATUS[0]}
        set -e
    else
        set +e
        "${command[@]}" 2>&1 | redact_sensitive >>"$LOG_FILE"
        status=${PIPESTATUS[0]}
        set -e
    fi

    if (( status != 0 )); then
        printf 'FAILED (%s): %s\n' "$status" "$label" | redact_sensitive >>"$LOG_FILE"
    fi
    return "$status"
}

run_sudo() {
    local label=$1
    shift
    run_cmd "$label" "$(command -v sudo)" -- "$@"
}

run_quiet() {
    run_cmd "$@"
}

run_capture() {
    local variable=${1:-} label=${2:-}
    local captured_output='' status=0
    shift 2
    local -a command=("$@")

    [[ -n $variable ]] || return 2
    printf -v "$variable" '%s' ''

    if (( DRY_RUN )); then
        dry_run_msg "${command[@]}"
        return 0
    fi

    _log_command "${command[@]}"
    (( VERBOSE )) && _print_command "${command[@]}"
    set +e
    captured_output=$("${command[@]}" 2>&1)
    status=$?
    set -e
    printf '%s\n' "$captured_output" | redact_sensitive >>"$LOG_FILE"
    (( VERBOSE )) && printf '%s\n' "$captured_output" | redact_sensitive
    printf -v "$variable" '%s' "$captured_output"
    if (( status != 0 )); then
        printf 'FAILED (%s): %s\n' "$status" "$label" | redact_sensitive >>"$LOG_FILE"
    fi
    return "$status"
}
